{
  "name": "raydium-cli-v0",
  "version": "0.1.1",
  "description": "CLI tool for interacting with Raydium on Solana — swap, manage CLMM/CPMM positions, launch tokens, and more",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xStendhal/raydium-cli-v0.git"
  },
  "homepage": "https://github.com/0xStendhal/raydium-cli-v0#readme",
  "bugs": {
    "url": "https://github.com/0xStendhal/raydium-cli-v0/issues"
  },
  "bin": {
    "raydium": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "postinstall": "node scripts/force-bigint-buffer-js.js",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "npm run build && node --test dist/lib/*.test.js tests/*.test.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "raydium",
    "solana",
    "cli",
    "defi",
    "clmm",
    "cpmm",
    "swap",
    "liquidity",
    "launchpad"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@raydium-io/raydium-sdk-v2": "0.2.59-alpha",
    "@solana/spl-token": "0.4.8",
    "@solana/web3.js": "1.95.3",
    "bip39": "3.1.0",
    "bn.js": "5.2.3",
    "bs58": "6.0.0",
    "chalk": "5.3.0",
    "commander": "11.1.0",
    "decimal.js": "10.6.0",
    "dotenv": "16.4.5",
    "inquirer": "9.3.8",
    "ora": "7.0.1",
    "pinata": "2.5.3",
    "typescript": "5.3.3"
  },
  "devDependencies": {
    "@types/bn.js": "5.2.0",
    "@types/inquirer": "9.0.7",
    "@types/node": "20.11.10",
    "ts-node": "10.9.2"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
